NEXT_PUBLIC_SANITY_PROJECT_ID="<paste your project here>" # Required - The ID of your Sanity project
NEXT_PUBLIC_SANITY_DATASET="production" # Required - The dataset of your Sanity project
NEXT_PUBLIC_SANITY_API_VERSION="2025-09-25" # Optional - The API version provided to the Sanity Client
NEXT_PUBLIC_SANITY_STUDIO_URL="" # Optional, defaults to http://localhost:3333. Set to the deployed Studio URL for production preview.
SANITY_API_READ_TOKEN="<paste your token here>" # Required anywhere Sanity Presentation / Visual Editing should work.
SANITY_REVALIDATE_SECRET="" # Required for production - Webhook secret for on-demand revalidation
